{
  "description": "CacheLayer PreToolUse lookup (fail-open). Not supported on Windows.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CODEX_PLUGIN_ROOT}/scripts/pre_tool_use.sh\"",
            "timeout": 2
          }
        ]
      }
    ]
  }
}
